---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";

const highlights = [
  "Marine Corps mechanical, electrical, and power-systems troubleshooting background.",
  "Autonomous vehicle testing experience through Glydways / SkillBridge.",
  "Hands-on robotics, FPV drone, embedded hardware, 3D printing, and automation builds.",
  "Self-directed technical learning centered on systems that can be built, tested, and revised.",
];

const technicalAreas = [
  "Robotics",
  "Embedded hardware",
  "Autonomous systems testing",
  "FPV drones",
  "3D printing",
  "Smart home automation",
  "Technical documentation",
];
---

<BaseLayout title="About | NearDivine Labs">
  <main class="mx-auto max-w-6xl px-6 pb-24 pt-32">
    <section class={layout.aboutHeroGrid}>
      <div>
        <PageEyebrow label="About me" />

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          From Marine Corps troubleshooting to robotics, autonomy, and embedded hardware.
        </h1>

        <div class="mt-8 max-w-3xl space-y-6 text-base leading-8 text-zinc-400">
          <p>
            My background started with mechanical and electrical troubleshooting in the Marine Corps and moved into autonomous vehicle testing through Glydways / SkillBridge. This site documents the transition into robotics, embedded hardware, FPV drones, 3D printing, and automation.
          </p>

          <p>
            NearDivine Labs is written as evidence, not polish. Projects include prototypes, wiring, failures, debug notes, repairs, upgrades, and test results so the work can be judged from what was actually built.
          </p>
        </div>
      </div>

      <aside class={`${surfaces.card} p-6`}>
        <div class={`aspect-square ${media.heroFrame}`}>
          <div class="flex h-full items-center justify-center px-6 text-center">
            <PageEyebrow label="Profile image pending" />
          </div>
        </div>

        <div class={`mt-6 ${surfaces.stat} p-5`}>
          <PageEyebrow label="Current direction" />
          <p class="mt-4 text-sm leading-7 text-zinc-400">
            Robotics, embedded hardware, autonomous systems testing, control bring-up, and technical documentation.
          </p>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {highlights.map((item) => (
          <div class={`${surfaces.card} p-5 text-sm font-medium leading-7 text-zinc-300`}>
            {item}
          </div>
        ))}
      </div>
    </section>

    <section class="pt-20">
      <PageEyebrow label="Focus" />

      <h2 class={`mt-3 ${typography.subsectionTitle}`}>
        Technical areas
      </h2>

      <div class="mt-8 flex flex-wrap gap-3">
        {technicalAreas.map((area) => (
          <span class={`${surfaces.pill} px-4 py-2 font-semibold text-zinc-300`}>
            {area}
          </span>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
