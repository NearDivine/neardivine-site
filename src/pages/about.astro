---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { layout, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";

const highlights = [
  "Marine Corps electrical, mechanical, and field-power diagnostics.",
  "Autonomous-vehicle testing and systems validation at Glydways.",
  "Independent embedded hardware, robotics, sensor, and actuator projects.",
  "Technical documentation centered on failures, fixes, tests, and revisions.",
];

const technicalAreas = [
  "Systems integration",
  "Autonomy validation",
  "Embedded hardware",
  "Electrical diagnostics",
  "Linux compute",
  "Ethernet networking",
  "Hardware test",
];
---

<BaseLayout
  title="About | NearDivine Labs"
  description="Background in robotics systems integration, autonomous-vehicle validation, embedded hardware, and electromechanical troubleshooting."
>
  <main class={`${layout.pageShell} pb-24`}>
    <section class={layout.homeHeroGrid}>
      <div>
        <PageEyebrow label="About me" />

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Systems troubleshooting shaped how I approach robotics and autonomy.
        </h1>

        <div class="mt-8 max-w-3xl space-y-6 text-base leading-8 text-zinc-400">
          <p>
            My technical background began with generator systems, electrical
            diagnostics, mechanical repair, and field-power distribution in the
            Marine Corps. I now apply that troubleshooting foundation to
            autonomous-vehicle testing and systems validation at Glydways.
          </p>

          <p>
            Across professional work and independent projects, I focus on the
            interfaces where systems usually fail: power, wiring, networking,
            sensors, compute, actuators, mechanical packaging, test setup, and
            operating procedure.
          </p>
        </div>
      </div>

      <aside class={surfaces.panelStrong}>
        <PageEyebrow label="Professional direction" />

        <h2 class={`mt-3 ${typography.cardTitle}`}>
          Robotics systems integration and hardware validation.
        </h2>

        <div class="mt-6 grid gap-3">
          <div class={surfaces.stat}>
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
              Current work
            </p>

            <p class="mt-2 text-sm font-semibold text-white">
              Autonomous-vehicle field testing
            </p>
          </div>

          <div class={surfaces.stat}>
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
              Core method
            </p>

            <p class="mt-2 text-sm font-semibold text-white">
              Diagnose, integrate, test, and document
            </p>
          </div>

          <div class={surfaces.stat}>
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">
              Target roles
            </p>

            <p class="mt-2 text-sm font-semibold text-white">
              Systems integration, hardware test, and autonomy validation
            </p>
          </div>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {highlights.map((item) => (
          <div class={`${surfaces.card} p-5 text-sm font-medium leading-7 text-zinc-300`}>
            {item}
          </div>
        ))}
      </div>
    </section>

    <section class={layout.section}>
      <PageEyebrow label="Focus" />

      <h2 class={`mt-3 ${typography.subsectionTitle}`}>
        Technical areas
      </h2>

      <div class="mt-8 flex flex-wrap gap-3">
        {technicalAreas.map((area) => (
          <span class={`${surfaces.pill} px-4 py-2 font-semibold text-zinc-300`}>
            {area}
          </span>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>