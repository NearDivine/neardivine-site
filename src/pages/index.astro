---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";
import Nav from "../components/Nav.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { focusProjects, recentLogs } from "../data/projects";
import "../styles/global.css";

const recentPreview = recentLogs.slice(0, 6);
const profileImage = "/images/profile/profile.jpg";

const professionalHighlights = [
  {
    title: "Autonomous-Vehicle Validation",
    note: "Sensor testing, repeatable environmental validation, system troubleshooting, and test-infrastructure recovery at Glydways.",
    tag: "Glydways",
  },
  {
    title: "Electrical & Mechanical Diagnostics",
    note: "Generator systems, field power distribution, schematics, preventive maintenance, and independent fault isolation.",
    tag: "USMC",
  },
  {
    title: "Embedded Hardware Prototyping",
    note: "ESP32 and STM32 development, sensor integration, actuator control, DC power, Linux compute, and networked devices.",
    tag: "Projects",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>NearDivine Labs</title>
  </head>

  <body class={`min-h-screen ${colors.pageBackground} text-white antialiased`}>
    <Nav />

    <main class={layout.pageShell}>
      <section class={layout.homeHeroGrid}>
        <div>
          <PageEyebrow label="NearDivine Labs" class="mb-5" />

          <h1 class={`mt-4 ${typography.heroTitle}`}>
            Robotics systems integration and embedded hardware.
          </h1>

          <div class="mt-7 max-w-2xl space-y-4 text-base leading-8 text-zinc-400">
            <p>
              I build, troubleshoot, and validate electromechanical systems spanning sensors, embedded electronics, Linux compute, Ethernet networking, DC power, and physical test infrastructure.
            </p>

            <p>
              My background combines autonomous-vehicle testing at Glydways, Marine Corps electrical and mechanical diagnostics, and independently built embedded systems.
            </p>
          </div>

          <div class="mt-9 flex flex-wrap gap-4">
            <a
              href="/work"
              class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-black transition hover:bg-zinc-200"
            >
              View selected work
            </a>

            <a
              href="/resume/Tyler_Funk_Resume.pdf"
              download="Tyler_Funk_Resume.pdf"
              class={`${surfaces.buttonSecondary} px-5 ${typography.actionText}`}
            >
              Download resume
            </a>
          </div>
        </div>

        <aside class="hidden lg:block">
          <div class={surfaces.panelStrong}>
            <div class={`flex items-start justify-between gap-6 border-b ${colors.border} pb-5`}>
              <div>
                <PageEyebrow label="Professional Snapshot" />

                <h2 class={`mt-2 ${typography.cardTitle}`}>
                  Systems experience
                </h2>
              </div>

              <span class={`${surfaces.pill} text-xs font-medium text-zinc-300`}>
                Current
              </span>
            </div>

            <div class="mt-6 space-y-3">
              {professionalHighlights.map((item) => (
                <div class={`${surfaces.card} p-5`}>
                  <div class="flex items-start justify-between gap-5">
                    <div>
                      <h3 class="text-base font-semibold leading-snug text-white">
                        {item.title}
                      </h3>

                      <p class="mt-2 text-sm leading-6 text-zinc-400">
                        {item.note}
                      </p>
                    </div>

                    <span class={`${surfaces.smallPill} shrink-0 text-xs`}>
                      {item.tag}
                    </span>
                  </div>
                </div>
              ))}
            </div>

            <div class={`mt-6 grid gap-4 border-t ${colors.border} pt-5 sm:grid-cols-3`}>
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Focus
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Integration
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Method
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Diagnose + validate
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Scope
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Hardware + systems
                </p>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section class={layout.section}>
        <SectionHeader eyebrow="Professional work" title="Experience" />

        <div class="grid gap-6 lg:grid-cols-2">
          <article class={`${surfaces.card} p-7`}>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class={`text-sm font-semibold uppercase tracking-[0.16em] ${colors.accentSoft}`}>
                  Glydways
                </p>

                <h3 class="mt-2 text-xl font-semibold text-white">
                  Field Test Specialist
                </h3>
              </div>

              <span class={surfaces.smallPill}>
                Oct 2025–Present
              </span>
            </div>

            <p class="mt-5 text-sm leading-7 text-zinc-400">
              Autonomous-vehicle testing and systems validation spanning sensors,
              DC power, Linux compute, Ethernet networking, data logging, fluid
              systems, and physical test infrastructure.
            </p>

            <ul class="mt-5 space-y-3 text-sm leading-7 text-zinc-300">
              <li>
                Recovered and developed an initial rain-simulation capability for
                autonomous-vehicle sensor-cleaning validation.
              </li>

              <li>
                Diagnosed faults across power, networking, remote access, thermal
                management, plumbing, and camera and LiDAR logging.
              </li>

              <li>
                Established repeatable test positioning and documentation, then
                executed validation using the formalized engineering test cart.
              </li>
            </ul>
          </article>

          <article class={`${surfaces.card} p-7`}>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class={`text-sm font-semibold uppercase tracking-[0.16em] ${colors.accentSoft}`}>
                  United States Marine Corps
                </p>

                <h3 class="mt-2 text-xl font-semibold text-white">
                  Generator Mechanic
                </h3>
              </div>

              <span class={surfaces.smallPill}>
                2022–Jan 2026
              </span>
            </div>

            <p class="mt-5 text-sm leading-7 text-zinc-400">
              Electrical and mechanical diagnostics, maintenance, and repair for
              generator systems, field power distribution, and associated
              electromechanical equipment.
            </p>

            <ul class="mt-5 space-y-3 text-sm leading-7 text-zinc-300">
              <li>
                Traced circuits using schematics, wiring diagrams, and electrical
                test equipment.
              </li>

              <li>
                Maintained generator systems and parallel power configurations
                under field and facility constraints.
              </li>

              <li>
                Completed independent fault isolation while maintaining safety,
                documentation, and mission-readiness requirements.
              </li>
            </ul>
          </article>
        </div>

        <div class="mt-8">
          <a
            href="/resume/Tyler_Funk_Resume.pdf"
            download="Tyler_Funk_Resume.pdf"
            class={`inline-flex items-center ${surfaces.buttonSecondary} px-5 text-zinc-300 hover:text-white ${typography.actionText}`}
          >
            Download full resume
          </a>
        </div>
      </section>

      <section class={layout.section}>
        <SectionHeader eyebrow="Current focus" title="Active Builds" />

        <div class={layout.cardGrid}>
          {focusProjects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </section>

      <section class={layout.section}>
        <SectionHeader eyebrow="Recent work" title="Build Logs & Experiments" />

        <div class={layout.cardGrid}>
          {recentPreview.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href="/work"
            class={`inline-flex items-center ${surfaces.buttonSecondary} px-5 text-zinc-300 hover:text-white ${typography.actionText}`}
          >
            See more work
          </a>
        </div>
      </section>

      <section class={layout.section}>
        <div class={layout.homeAboutGrid}>
          <div>
            <PageEyebrow label="About Me" class="mb-5" />

            <h2 class={typography.featureTitle}>
              I came into robotics through field work, broken hardware, and unfinished prototypes.
            </h2>

            <div class="mt-8 max-w-3xl space-y-6 text-base leading-8 text-zinc-400">
              <p>
                My background started with mechanical and electrical troubleshooting in the Marine Corps and moved into autonomous vehicle testing through Glydways / SkillBridge. This site documents the transition into robotics, embedded hardware, FPV drones, 3D printing, and automation.
              </p>

              <p>
                This portfolio is the record of that progression. I am not presenting the work as perfect or
                finished. The point is to show the actual technical path: what I built, what I misunderstood,
                what failed under test, what I fixed, and how each project moves me closer to deeper robotics,
                autonomy, and practical engineering skill.
              </p>
            </div>

            <div class="mt-8">
              <a
                href="/about"
                class={`inline-flex items-center ${surfaces.buttonSecondary} px-5 text-zinc-300 hover:text-white ${typography.actionText}`}
              >
                More about me
              </a>
            </div>
          </div>

          <div class={`overflow-hidden ${surfaces.card} p-4`}>
            <div class={`aspect-[4/5] overflow-hidden rounded-2xl ${colors.surfaceStrong}`}>
              <div class="grid h-full min-h-72 w-full place-items-center rounded-2xl border border-dashed border-zinc-800 bg-zinc-950/70 p-6 text-center">
                <div>
                  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-zinc-300">NearDivine Labs</p>
                  <p class="mt-3 text-sm leading-6 text-zinc-500">Profile image placeholder</p>
                </div>
              </div>

              <div class="hidden h-full w-full items-center justify-center px-8 text-center">
                <span class={typography.eyebrowMuted}>
                  Profile Image Pending
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

