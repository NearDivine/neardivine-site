---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";
import Nav from "../components/Nav.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { focusProjects, recentLogs } from "../data/projects";
import "../styles/global.css";

const recentPreview = recentLogs.slice(0, 6);
const profileImage = "/images/profile/profile.jpg";

const focusProjectNotes: Record<string, string> = {
  "Robotic Spider Platform": "Legged robotics, actuator packaging, control experiments, and staged prototype revisions.",
  "Custom FPV Quadcopter": "Flight-controller wiring, ELRS setup, Betaflight configuration, and hardware bring-up.",
  "Used 3D Printer Restoration & Interface Upgrade":
    "Printer repair, tuning, interface cleanup, and practical tooling for future hardware work.",
};

const getFocusNote = (title: string) =>
  focusProjectNotes[title] ?? "Active hardware project with build notes, tests, and revision history.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>NearDivine Labs</title>
  </head>

  <body class={`min-h-screen ${colors.pageBackground} text-white antialiased`}>
    <Nav />

    <main class={layout.pageShell}>
      <section class={layout.homeHeroGrid}>
        <div>
          <PageEyebrow label="NearDivine Labs" class="mb-5" />

          <h1 class={`mt-4 ${typography.heroTitle}`}>
            Robotics, embedded hardware, and autonomy projects built through testing, debugging, and iteration.
          </h1>

          <div class="mt-7 max-w-2xl space-y-4 text-base leading-8 text-zinc-400">
            <p>
              A technical portfolio covering robotics, drones, embedded systems, automation, repair work, and autonomous systems testing.
            </p>

            <p>
              The site focuses on engineering evidence: wiring, bring-up, test notes, failure analysis, working prototypes, and the revisions that moved each system closer to working.
            </p>
          </div>

          <div class="mt-9 flex flex-wrap gap-4">
            <a
              href="/work"
              class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-black transition hover:bg-zinc-200"
            >
              View work
            </a>

            <a
              href="/about"
              class={`${surfaces.buttonSecondary} px-5 ${typography.actionText}`}
            >
              About
            </a>
          </div>
        </div>

        <aside class="hidden lg:block">
          <div class={surfaces.panelStrong}>
            <div class={`flex items-start justify-between gap-6 border-b ${colors.border} pb-5`}>
              <div>
                <PageEyebrow label="Engineering Snapshot" />

                <h2 class={`mt-2 ${typography.cardTitle}`}>
                  Current project work
                </h2>
              </div>

              <span class={`${surfaces.pill} text-xs font-medium text-zinc-300`}>
                Active
              </span>
            </div>

            <div class="mt-6 space-y-3">
              {focusProjects.map((project) => (
                <a
                  href={project.href}
                  class={`block ${surfaces.cardInteractive} p-5`}
                >
                  <div class="flex items-start justify-between gap-5">
                    <div>
                      <h3 class="text-base font-semibold leading-snug text-white">
                        {project.title}
                      </h3>

                      <p class="mt-2 text-sm leading-6 text-zinc-400">
                        {getFocusNote(project.title)}
                      </p>
                    </div>

                    <span class={`${surfaces.smallPill} shrink-0 text-xs`}>
                      {project.category}
                    </span>
                  </div>
                </a>
              ))}
            </div>

            <div class={`mt-6 grid gap-4 border-t ${colors.border} pt-5 sm:grid-cols-3`}>
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Focus
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Robotics
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Method
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Build logs
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">
                  Scope
                </p>

                <p class="mt-1 text-sm font-medium text-white">
                  Hardware
                </p>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section class={layout.section}>
        <SectionHeader eyebrow="Current focus" title="Active Builds" />

        <div class={layout.cardGrid}>
          {focusProjects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </section>

      <section class={layout.section}>
        <SectionHeader eyebrow="Recent work" title="Build Logs & Experiments" />

        <div class={layout.cardGrid}>
          {recentPreview.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href="/work"
            class={`inline-flex items-center ${surfaces.buttonSecondary} px-5 text-zinc-300 hover:text-white ${typography.actionText}`}
          >
            See more work
          </a>
        </div>
      </section>

      <section class={layout.section}>
        <div class={layout.homeAboutGrid}>
          <div>
            <PageEyebrow label="About Me" class="mb-5" />

            <h2 class={typography.featureTitle}>
              I came into robotics through field work, broken hardware, and unfinished prototypes.
            </h2>

            <div class="mt-8 max-w-3xl space-y-6 text-base leading-8 text-zinc-400">
              <p>
                My background started with mechanical and electrical troubleshooting in the Marine Corps and moved into autonomous vehicle testing through Glydways / SkillBridge. This site documents the transition into robotics, embedded hardware, FPV drones, 3D printing, and automation.
              </p>

              <p>
                This portfolio is the record of that progression. I am not presenting the work as perfect or
                finished. The point is to show the actual technical path: what I built, what I misunderstood,
                what failed under test, what I fixed, and how each project moves me closer to deeper robotics,
                autonomy, and practical engineering skill.
              </p>
            </div>

            <div class="mt-8">
              <a
                href="/about"
                class={`inline-flex items-center ${surfaces.buttonSecondary} px-5 text-zinc-300 hover:text-white ${typography.actionText}`}
              >
                More about me
              </a>
            </div>
          </div>

          <div class={`overflow-hidden ${surfaces.card} p-4`}>
            <div class={`aspect-[4/5] overflow-hidden rounded-2xl ${colors.surfaceStrong}`}>
              <img
                src={profileImage}
                alt="NearDivine Labs profile"
                class="h-full w-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />

              <div class="hidden h-full w-full items-center justify-center px-8 text-center">
                <span class={typography.eyebrowMuted}>
                  Profile Image Pending
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

