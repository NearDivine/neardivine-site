---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SectionHeader from "../../../components/SectionHeader.astro";
import { typography } from "../../../styles/typography";
import { colors, layout, media, surfaces } from "../../../styles/siteStyles";
import { allProjects } from "../../../data/projects";

export function getStaticPaths() {
  return allProjects.flatMap((project) =>
    (project.profiles ?? []).map((profile) => ({
      params: {
        slug: project.slug,
        profile: profile.slug,
      },
      props: {
        project,
        profile,
      },
    }))
  );
}

const { project, profile } = Astro.props;

const gallery = profile.gallery ?? [];
const stats = profile.stats ?? [];
const personalWork = profile.sections?.personalWork ?? [];
const problems = profile.sections?.problems ?? [];
const worked = profile.sections?.worked ?? [];
const unfinished = profile.sections?.unfinished ?? [];
const getGalleryFrameClass = (variant: string = "gallery") => {
  const frames: Record<string, string> = {
    hero: "aspect-video",
    card: "aspect-[4/3]",
    gallery: "aspect-[4/3]",
    technical: "aspect-[4/3]",
    portrait: "aspect-[3/4]",
  };

  return frames[variant] ?? frames.gallery;
};

const getQualityLabel = (quality?: string) => {
  const labels: Record<string, string> = {
    portfolio: "Portfolio",
    process: "Process",
    archive: "Archive",
  };

  return quality ? labels[quality] ?? quality : null;
};
---

<BaseLayout title={`${profile.title} | ${project.title} | NearDivine Labs`}>
  <main class={layout.pageShell}>
    <section class={layout.heroGrid}>
      <div>
        <p class={`mb-6 ${typography.eyebrow}`}>
          {project.title}
        </p>

        <h1 class={typography.pageTitle}>
          {profile.title}
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
          {profile.summary}
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class={surfaces.activePill}>
            {profile.status}
          </span>

          {profile.tags?.map((tag) => (
            <span class={surfaces.pill}>
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class={`overflow-hidden ${surfaces.panel}`}>
        <div class={media.heroFrame}>
          {profile.image ? (
            <img
              src={profile.image}
              alt={profile.title}
              class="h-full w-full object-cover"
              decoding="async"
            />
          ) : (
            <div class="flex h-full items-center justify-center px-8 text-center">
              <span class={`text-xs ${typography.eyebrow} ${colors.accentSoft}`}>
                Project Visual Pending
              </span>
            </div>
          )}
        </div>

        {stats.length > 0 && (
          <div class="mt-5 grid gap-3">
            {stats.map((stat) => (
              <div class={surfaces.stat}>
                {stat}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class={layout.sectionBottomTight}>
      <SectionHeader eyebrow="Overview" title="Profile Summary" />

      <p class="max-w-3xl text-lg leading-8 text-zinc-400">
        {profile.description}
      </p>
    </section>

    {profile.sections && (
      <>
        <section class={layout.twoColumnGrid}>
          <div class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>What I built</h2>
            <p class="mt-4 leading-7 text-zinc-400">{profile.sections.built}</p>
          </div>

          <div class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Why I built it</h2>
            <p class="mt-4 leading-7 text-zinc-400">{profile.sections.why}</p>
          </div>
        </section>

        {profile.hardware && profile.hardware.length > 0 && (
          <section class={layout.sectionBottom}>
            <SectionHeader eyebrow="System" title="Core Hardware" />

            <div class={`overflow-hidden rounded-2xl border ${colors.border}`}>
              <table class="w-full border-collapse text-left text-sm">
                <tbody>
                  {profile.hardware.map(([subsystem, component]) => (
                    <tr class={`border-b ${colors.border} last:border-b-0`}>
                      <th class={`w-1/3 ${colors.surface} px-5 py-4 align-top font-semibold text-zinc-300`}>
                        {subsystem}
                      </th>
                      <td class="px-5 py-4 leading-6 text-zinc-400">
                        {component}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {personalWork.length > 0 && (
          <section class={layout.sectionBottom}>
            <SectionHeader eyebrow="Build process" title="What I Personally Did" />

            <div class="grid gap-3 md:grid-cols-2">
              {personalWork.map((item) => (
                <div class={`${surfaces.card} p-4 text-sm leading-6 text-zinc-300`}>
                  {item}
                </div>
              ))}
            </div>
          </section>
        )}

        <section class={layout.threeColumnGrid}>
          <article class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Problems I ran into</h2>

            <div class="mt-4 space-y-4">
              {problems.map((item) => (
                <p class="leading-7 text-zinc-400">{item}</p>
              ))}
            </div>
          </article>

          <article class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>What worked</h2>

            <ul class="mt-4 space-y-3">
              {worked.map((item) => (
                <li class="text-sm leading-6 text-zinc-400">• {item}</li>
              ))}
            </ul>
          </article>

          <article class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Remaining work</h2>

            <ul class="mt-4 space-y-3">
              {unfinished.map((item) => (
                <li class="text-sm leading-6 text-zinc-400">• {item}</li>
              ))}
            </ul>
          </article>
        </section>

        <section class={layout.sectionBottom}>
          <SectionHeader eyebrow="Takeaway" title="What I Learned" />

          <p class="max-w-3xl text-lg leading-8 text-zinc-400">
            {profile.sections.learned}
          </p>
        </section>
      </>
    )}

    {gallery.length > 0 && (
      <section class={layout.sectionBottom}>
        <SectionHeader eyebrow="Evidence" title="Build Gallery" />

        <div class={layout.cardGrid}>
          {gallery.map((item) => (
            <figure class={`overflow-hidden ${surfaces.card}`}>
              <div class={`${getGalleryFrameClass(item.variant)} overflow-hidden bg-zinc-950`}>
                <img
                  src={item.src}
                  alt={item.alt ?? item.title}
                  class="h-full w-full object-cover transition duration-300 hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <figcaption class="p-5">
                <h3 class={typography.galleryTitle}>{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-400">
                  {item.caption}
                </p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <section class={`flex flex-wrap gap-4 ${layout.sectionBottom}`}>
      <a
        href={project.href}
        class={`${surfaces.buttonPrimary} ${typography.actionText}`}
      >
        Back to {project.title}
      </a>

      <a
        href="/work"
        class={`${surfaces.buttonSecondary} ${typography.actionText}`}
      >
        All work
      </a>
    </section>
  </main>
</BaseLayout>