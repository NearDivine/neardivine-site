---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { allProjects } from "../../data/projects";

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const gallery = project.gallery ?? [];
const stats = project.stats ?? [];
const profiles = project.profiles ?? [];
const personalWork = project.sections?.personalWork ?? [];
const problems = project.sections?.problems ?? [];
const worked = project.sections?.worked ?? [];
const unfinished = project.sections?.unfinished ?? [];
---

<BaseLayout title={`${project.title} | NearDivine Labs`}>
  <main class="mx-auto max-w-6xl px-6 pt-32">
    <section class="grid gap-12 pb-20 lg:grid-cols-[1fr_0.8fr] lg:items-start">
      <div>
        <p class="mb-6 text-xs font-semibold uppercase tracking-[0.35em] text-blue-400">
          {project.category}
        </p>

        <h1 class="max-w-4xl text-5xl font-black tracking-tight text-white md:text-7xl">
          {project.title}
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
          {project.summary}
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="rounded-full bg-blue-500/15 px-3 py-1 text-sm font-semibold text-blue-300">
            {project.status}
          </span>

          {project.tags?.map((tag) => (
            <span class="rounded-full border border-white/10 px-3 py-1 text-sm text-zinc-400">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-6">
        <div class="aspect-video overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-blue-500/20 via-zinc-900 to-black">
          {project.image ? (
            <img
              src={project.image}
              alt={project.title}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full items-center justify-center px-8 text-center">
              <span class="text-xs font-semibold uppercase tracking-[0.25em] text-blue-300">
                Project Visual Pending
              </span>
            </div>
          )}
        </div>

        {stats.length > 0 && (
          <div class="mt-5 grid gap-3">
            {stats.map((stat) => (
              <div class="rounded-xl border border-white/10 bg-black/20 p-4 text-sm font-semibold text-zinc-300">
                {stat}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="pb-20">
      <SectionHeader eyebrow="Overview" title="Project Summary" />

      <p class="max-w-3xl text-lg leading-8 text-zinc-400">
        {project.description}
      </p>
    </section>

    {profiles.length > 0 && (
      <section class="pb-24">
        <SectionHeader eyebrow="Project branches" title="Prototype Profiles" />

        <div class="grid items-start gap-6 md:grid-cols-2 lg:grid-cols-3">
          {profiles.map((profile) => (
            <a
              href={profile.href}
              class="group flex h-[430px] max-w-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] transition duration-300 hover:-translate-y-1 hover:border-blue-400/40 hover:bg-white/[0.05]"
            >
              <div class="h-40 shrink-0 overflow-hidden border-b border-white/10 bg-gradient-to-br from-blue-500/20 via-zinc-900 to-black">
                {profile.image ? (
                  <img
                    src={profile.image}
                    alt={profile.title}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center px-6 text-center">
                    <span class="text-[0.6rem] font-bold uppercase tracking-[0.35em] text-blue-300">
                      NearDivine Labs
                    </span>
                  </div>
                )}
              </div>

              <div class="flex min-h-0 flex-1 flex-col p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <p class="project-profile-category max-w-[68%] text-[0.62rem] font-black uppercase tracking-[0.22em] text-blue-400">
                    {profile.category}
                  </p>

                  <span class="shrink-0 rounded-full border border-white/10 px-2.5 py-1 text-[0.62rem] font-semibold text-zinc-400">
                    {profile.status}
                  </span>
                </div>

                <h3 class="project-profile-title text-lg font-black leading-tight text-white">
                  {profile.title}
                </h3>

                <p class="project-profile-summary mt-3 text-sm leading-6 text-zinc-400">
                  {profile.summary}
                </p>

                <div class="mt-auto pt-5">
                  <span class="text-sm font-bold text-blue-300 group-hover:text-blue-200">
                    Open profile →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {project.sections ? (
      <>
        <section class="grid gap-6 pb-24 md:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <h2 class="text-2xl font-black text-white">What I built</h2>
            <p class="mt-4 leading-7 text-zinc-400">{project.sections.built}</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <h2 class="text-2xl font-black text-white">Why I built it</h2>
            <p class="mt-4 leading-7 text-zinc-400">{project.sections.why}</p>
          </div>
        </section>

        {project.hardware && project.hardware.length > 0 && (
          <section class="pb-24">
            <SectionHeader eyebrow="System" title="Core Hardware" />

            <div class="overflow-hidden rounded-2xl border border-white/10">
              <table class="w-full border-collapse text-left text-sm">
                <tbody>
                  {project.hardware.map(([subsystem, component]) => (
                    <tr class="border-b border-white/10 last:border-b-0">
                      <th class="w-1/3 bg-white/[0.03] px-5 py-4 align-top font-semibold text-zinc-300">
                        {subsystem}
                      </th>
                      <td class="px-5 py-4 leading-6 text-zinc-400">
                        {component}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {personalWork.length > 0 && (
          <section class="pb-24">
            <SectionHeader eyebrow="Build process" title="What I Personally Did" />

            <div class="grid gap-3 md:grid-cols-2">
              {personalWork.map((item) => (
                <div class="rounded-xl border border-white/10 bg-white/[0.03] p-4 text-sm leading-6 text-zinc-300">
                  {item}
                </div>
              ))}
            </div>
          </section>
        )}

        <section class="grid items-start gap-6 pb-24 lg:grid-cols-3">
          <article class="expand-card flex min-h-[390px] flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <h2 class="text-2xl font-black text-white">Problems I ran into</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <div class="space-y-4">
                {problems.map((item) => (
                  <p class="leading-7 text-zinc-400">{item}</p>
                ))}
              </div>

              <div class="expand-fade pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-[#0b0c10] to-transparent"></div>
            </div>

            <button
              type="button"
              class="expand-toggle mt-auto pt-4 text-left text-sm font-bold text-blue-300 hover:text-blue-200"
            >
              Read more
            </button>
          </article>

          <article class="expand-card flex min-h-[390px] flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <h2 class="text-2xl font-black text-white">What worked</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <ul class="space-y-3">
                {worked.map((item) => (
                  <li class="text-sm leading-6 text-zinc-400">• {item}</li>
                ))}
              </ul>

              <div class="expand-fade pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-[#0b0c10] to-transparent"></div>
            </div>

            <button
              type="button"
              class="expand-toggle mt-auto pt-4 text-left text-sm font-bold text-blue-300 hover:text-blue-200"
            >
              Read more
            </button>
          </article>

          <article class="expand-card flex min-h-[390px] flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-6">
            <h2 class="text-2xl font-black text-white">Remaining work</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <ul class="space-y-3">
                {unfinished.map((item) => (
                  <li class="text-sm leading-6 text-zinc-400">• {item}</li>
                ))}
              </ul>

              <div class="expand-fade pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-[#0b0c10] to-transparent"></div>
            </div>

            <button
              type="button"
              class="expand-toggle mt-auto pt-4 text-left text-sm font-bold text-blue-300 hover:text-blue-200"
            >
              Read more
            </button>
          </article>
        </section>

        <section class="pb-24">
          <SectionHeader eyebrow="Takeaway" title="What I Learned" />

          <p class="max-w-3xl text-lg leading-8 text-zinc-400">
            {project.sections.learned}
          </p>
        </section>
      </>
    ) : (
      <section class="pb-24">
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <h2 class="text-2xl font-black text-white">Case study in progress</h2>
          <p class="mt-4 max-w-3xl leading-7 text-zinc-400">
            This project page is currently a structured placeholder. Full project notes,
            images, hardware details, and build process documentation will be added as the
            portfolio is expanded.
          </p>
        </div>
      </section>
    )}

    {gallery.length > 0 && (
      <section class="pb-24">
        <SectionHeader eyebrow="Evidence" title="Build Gallery" />

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {gallery.map((item) => (
            <figure class="overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
              <div class="aspect-video overflow-hidden bg-zinc-950">
                <img
                  src={item.src}
                  alt={item.title}
                  class="h-full w-full object-cover transition duration-300 hover:scale-105"
                />
              </div>

              <figcaption class="p-5">
                <h3 class="text-lg font-bold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-400">
                  {item.caption}
                </p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <section class="flex flex-wrap gap-4 pb-24">
      <a
        href="/work"
        class="rounded-full bg-white px-6 py-3 text-sm font-bold text-black transition hover:bg-blue-100"
      >
        Back to work
      </a>

      <a
        href="/contact"
        class="rounded-full border border-white/10 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/5"
      >
        Contact
      </a>
    </section>
  </main>

  <script>
    document.querySelectorAll(".expand-card").forEach((card) => {
      const content = card.querySelector(".expand-content");
      const fade = card.querySelector(".expand-fade");
      const button = card.querySelector(".expand-toggle");

      if (!(content instanceof HTMLElement)) return;
      if (!(button instanceof HTMLButtonElement)) return;

      const collapsedHeight = 245;
      let expanded = false;

      const update = () => {
        const needsToggle = content.scrollHeight > collapsedHeight + 12;

        if (!needsToggle) {
          content.style.maxHeight = "none";
          button.classList.add("hidden");

          if (fade instanceof HTMLElement) {
            fade.classList.add("hidden");
          }

          return;
        }

        button.classList.remove("hidden");

        if (expanded) {
          content.style.maxHeight = `${content.scrollHeight}px`;
          button.textContent = "Show less";

          if (fade instanceof HTMLElement) {
            fade.classList.add("hidden");
          }
        } else {
          content.style.maxHeight = `${collapsedHeight}px`;
          button.textContent = "Read more";

          if (fade instanceof HTMLElement) {
            fade.classList.remove("hidden");
          }
        }
      };

      button.addEventListener("click", () => {
        expanded = !expanded;
        update();
      });

      window.addEventListener("resize", update);
      update();
    });
  </script>

  <style>
    .project-profile-category,
    .project-profile-title,
    .project-profile-summary {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .project-profile-category {
      -webkit-line-clamp: 2;
    }

    .project-profile-title {
      -webkit-line-clamp: 2;
    }

    .project-profile-summary {
      -webkit-line-clamp: 5;
    }
  </style>
</BaseLayout>