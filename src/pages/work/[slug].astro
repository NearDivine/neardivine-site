---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import EvidenceGallery from "../../components/EvidenceGallery.astro";
import { typography } from "../../styles/typography";
import { colors, layout, media, surfaces } from "../../styles/siteStyles";
import { allProjects } from "../../data/projects";

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const gallery = project.gallery ?? [];
const video = project.video ?? null;
const videoSrc =
  video?.src?.includes("remote-safe-working")
    ? "/media/projects/remote-safe/remote-safe-working-web.mp4"
    : video?.src;
const stats = project.stats ?? [];
const profiles = project.profiles ?? [];
const personalWork = project.sections?.personalWork ?? [];
const problems = project.sections?.problems ?? [];
const worked = project.sections?.worked ?? [];
const unfinished = project.sections?.unfinished ?? [];

---

<BaseLayout title={`${project.title} | NearDivine Labs`}>
  <main class={layout.pageShell}>
    <section class={layout.heroGrid}>
      <div>
        <p class={`mb-6 ${typography.eyebrow}`}>
          {project.category}
        </p>

        <h1 class={typography.pageTitle}>
          {project.title}
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
          {project.summary}
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class={surfaces.activePill}>
            {project.status}
          </span>

          {project.tags?.map((tag) => (
            <span class={surfaces.pill}>
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class={`overflow-hidden ${surfaces.panel}`}>
        <div class={media.heroFrame}>
          {project.image ? (
            <img
              src={project.image}
              alt={project.title}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full items-center justify-center px-8 text-center">
              <span class={`text-xs ${typography.eyebrow} ${colors.accentSoft}`}>
                Project Visual Pending
              </span>
            </div>
          )}
        </div>

        {stats.length > 0 && (
          <div class="mt-5 grid gap-3">
            {stats.map((stat) => (
              <div class={surfaces.stat}>
                {stat}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class={layout.sectionBottomTight}>
      <SectionHeader eyebrow="Overview" title="Project Summary" />

      <p class="max-w-3xl text-lg leading-8 text-zinc-400">
        {project.description}
      </p>
    </section>

    {profiles.length > 0 && (
      <section class={layout.sectionBottom}>
        <SectionHeader eyebrow="Project branches" title="Prototype Profiles" />

        <div class={layout.cardGrid}>
          {profiles.map((profile) => (
            <a
              href={profile.href}
              class={`group flex h-full min-h-[560px] max-w-full flex-col overflow-hidden ${surfaces.profileCard}`}
            >
              <div class={media.cardFrame}>
                {profile.image ? (
                  <img
                    src={profile.image}
                    alt={`${profile.title} project profile thumbnail`}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center px-6 text-center">
                    <span class={`text-[0.6rem] font-semibold uppercase tracking-[0.35em] ${colors.accentSoft}`}>
                      NearDivine Labs
                    </span>
                  </div>
                )}
              </div>

              <div class="flex min-h-0 flex-1 flex-col p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <p class={`project-profile-category max-w-[68%] ${colors.accent} ${typography.tinyLabel}`}>
                    {profile.category}
                  </p>

                  <span class={`shrink-0 font-semibold ${surfaces.smallPill}`}>
                    {profile.status}
                  </span>
                </div>

                <h3 class={`project-profile-title ${typography.galleryTitle}`}>
                  {profile.title}
                </h3>

                <p class="project-profile-summary mt-3 text-sm leading-6 text-zinc-400">
                  {profile.summary}
                </p>

                <div class="mt-auto pt-5">
                  <span class={`${typography.actionText} ${colors.accentSoft} ${surfaces.groupActionHover}`}>
                    Open profile →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {project.sections ? (
      <>
        <section class={layout.twoColumnGrid}>
          <div class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>What I built</h2>
            <p class="mt-4 leading-7 text-zinc-400">{project.sections.built}</p>
          </div>

          <div class={`${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Why I built it</h2>
            <p class="mt-4 leading-7 text-zinc-400">{project.sections.why}</p>
          </div>
        </section>

        {project.hardware && project.hardware.length > 0 && (
          <section class={layout.sectionBottom}>
            <SectionHeader eyebrow="System" title="Core Hardware" />

            <div class={`overflow-hidden rounded-2xl border ${colors.border}`}>
              <table class="w-full border-collapse text-left text-sm">
                <tbody>
                  {project.hardware.map(([subsystem, component]) => (
                    <tr class={`border-b ${colors.border} last:border-b-0`}>
                      <th class={`w-1/3 ${colors.surface} px-5 py-4 align-top font-semibold text-zinc-300`}>
                        {subsystem}
                      </th>
                      <td class="px-5 py-4 leading-6 text-zinc-400">
                        {component}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {personalWork.length > 0 && (
          <section class={layout.sectionBottom}>
            <SectionHeader eyebrow="Build process" title="What I Personally Did" />

            <div class="grid gap-3 md:grid-cols-2">
              {personalWork.map((item) => (
                <div class={`${surfaces.card} p-4 text-sm leading-6 text-zinc-300`}>
                  {item}
                </div>
              ))}
            </div>
          </section>
        )}

        <section class={layout.threeColumnGrid}>
          <article class={`expand-card flex min-h-[390px] flex-col ${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Problems I ran into</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <div class="space-y-4">
                {problems.map((item) => (
                  <p class="leading-7 text-zinc-400">{item}</p>
                ))}
              </div>

              <div class={`expand-fade ${surfaces.expandFade}`}></div>
            </div>

            <button
              type="button"
              class={`expand-toggle mt-auto pt-4 text-left ${colors.accentSoft} ${surfaces.actionHover} ${typography.actionText}`}
            >
              Read more
            </button>
          </article>

          <article class={`expand-card flex min-h-[390px] flex-col ${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>What worked</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <ul class="space-y-3">
                {worked.map((item) => (
                  <li class="text-sm leading-6 text-zinc-400">• {item}</li>
                ))}
              </ul>

              <div class={`expand-fade ${surfaces.expandFade}`}></div>
            </div>

            <button
              type="button"
              class={`expand-toggle mt-auto pt-4 text-left ${colors.accentSoft} ${surfaces.actionHover} ${typography.actionText}`}
            >
              Read more
            </button>
          </article>

          <article class={`expand-card flex min-h-[390px] flex-col ${surfaces.card} p-6`}>
            <h2 class={typography.subsectionTitle}>Remaining work</h2>

            <div class="expand-content relative mt-4 overflow-hidden transition-all duration-300" style="max-height: 245px;">
              <ul class="space-y-3">
                {unfinished.map((item) => (
                  <li class="text-sm leading-6 text-zinc-400">• {item}</li>
                ))}
              </ul>

              <div class={`expand-fade ${surfaces.expandFade}`}></div>
            </div>

            <button
              type="button"
              class={`expand-toggle mt-auto pt-4 text-left ${colors.accentSoft} ${surfaces.actionHover} ${typography.actionText}`}
            >
              Read more
            </button>
          </article>
        </section>

        <section class={layout.sectionBottom}>
          <SectionHeader eyebrow="Takeaway" title="What I Learned" />

          <p class="max-w-3xl text-lg leading-8 text-zinc-400">
            {project.sections.learned}
          </p>
        </section>
      </>
    ) : (
      <section class={layout.sectionBottom}>
        <div class={`${surfaces.card} p-6`}>
          <h2 class={typography.subsectionTitle}>Case study in progress</h2>
          <p class="mt-4 max-w-3xl leading-7 text-zinc-400">
            This project page is currently a structured placeholder. Full project notes,
            images, hardware details, and build process documentation will be added as the
            portfolio is expanded.
          </p>
        </div>
      </section>
    )}

    {video && (
      <section class={layout.sectionBottom}>
        <SectionHeader eyebrow="Media" title={video.title ?? "Project Video"} />

        <div class={`overflow-hidden ${surfaces.card}`}>
          <div class="aspect-video bg-black">
            <video
              controls
              muted
              playsinline
              preload="metadata"
              poster={video.poster}
              class="h-full w-full object-contain"
            >
              <source src={videoSrc} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>

          {video.caption && (
            <div class={`border-t ${colors.border} p-5`}>
              <p class="text-sm leading-6 text-zinc-400">
                {video.caption}
              </p>
            </div>
          )}
        </div>
      </section>
    )}
    {gallery.length > 0 && (
      <EvidenceGallery
        images={gallery}
        eyebrow="Evidence"
        title="Project Evidence"
        description="Project photos grouped by build phase so older process documentation and newer standardized photos can coexist without weakening the presentation."
      />
    )}

    <section class={`flex flex-wrap gap-4 ${layout.sectionBottom}`}>
      <a
        href="/work"
        class={`${surfaces.buttonPrimary} ${typography.actionText}`}
      >
        Back to work
      </a>

      <a
        href="/contact"
        class={`${surfaces.buttonSecondary} ${typography.actionText}`}
      >
        Contact
      </a>
    </section>
  </main>

  <script>
    document.querySelectorAll(".expand-card").forEach((card) => {
      const content = card.querySelector(".expand-content");
      const fade = card.querySelector(".expand-fade");
      const button = card.querySelector(".expand-toggle");

      if (!(content instanceof HTMLElement)) return;
      if (!(button instanceof HTMLButtonElement)) return;

      const collapsedHeight = 245;
      let expanded = false;

      const update = () => {
        const needsToggle = content.scrollHeight > collapsedHeight + 12;

        if (!needsToggle) {
          content.style.maxHeight = "none";
          button.classList.add("hidden");

          if (fade instanceof HTMLElement) {
            fade.classList.add("hidden");
          }

          return;
        }

        button.classList.remove("hidden");

        if (expanded) {
          content.style.maxHeight = `${content.scrollHeight}px`;
          button.textContent = "Show less";

          if (fade instanceof HTMLElement) {
            fade.classList.add("hidden");
          }
        } else {
          content.style.maxHeight = `${collapsedHeight}px`;
          button.textContent = "Read more";

          if (fade instanceof HTMLElement) {
            fade.classList.remove("hidden");
          }
        }
      };

      button.addEventListener("click", () => {
        expanded = !expanded;
        update();
      });

      window.addEventListener("resize", update);
      update();
    });
  </script>

  <style>
    .project-profile-category,
    .project-profile-title,
    .project-profile-summary {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .project-profile-category {
      -webkit-line-clamp: 2;
    }

    .project-profile-title {
      -webkit-line-clamp: 2;
    }

    .project-profile-summary {
      -webkit-line-clamp: 5;
    }
  </style>
</BaseLayout>
