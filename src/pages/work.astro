---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import * as projectData from "../data/projects";

const projectModule = projectData as unknown as {
  projects?: any[];
  allProjects?: any[];
  projectList?: any[];
  default?: any[];
};

const projectList =
  projectModule.projects ??
  projectModule.allProjects ??
  projectModule.projectList ??
  projectModule.default ??
  [];

const categories = [
  "Robotics",
  "Drones",
  "3D Printing",
  "Smart Home",
  "Embedded Hardware",
  "Software Tools",
];

const documentationPoints = [
  {
    title: "Build context",
    body: "What was built, tested, repaired, or changed.",
  },
  {
    title: "Failure modes",
    body: "Wiring issues, wrong assumptions, broken parts, and fixes.",
  },
  {
    title: "Next revisions",
    body: "Unfinished work and likely next steps.",
  },
];
---

<BaseLayout title="Work | NearDivine Labs">
  <main class={`${layout.pageShell} pb-24`}>
    <section class={layout.homeHeroGrid}>
      <div>
        <PageEyebrow label="Work" />

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Projects, prototypes, build logs, and technical systems.
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-400">
          A portfolio of robotics, drones, embedded hardware, automation systems, 3D printing,
          software tools, and repair work documented through real build progress instead of polished
          summaries only.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {categories.map((category) => (
            <span class={`${surfaces.pill} px-4 py-2 font-semibold text-zinc-300`}>
              {category}
            </span>
          ))}
        </div>
      </div>

      <aside class={`overflow-hidden ${surfaces.panelStrong}`}>
        <div class="flex items-start justify-between gap-4">
          <div>
            <PageEyebrow label="Portfolio structure" />

            <h2 class={`mt-3 ${typography.cardTitle}`}>
              Project records, not just finished demos.
            </h2>
          </div>

          <span class={`${surfaces.pill} shrink-0 text-xs font-semibold text-zinc-300`}>
            Active
          </span>
        </div>

        <div class={`mt-6 border-t ${colors.border} pt-6`}>
          <div class="grid gap-3">
            {documentationPoints.map((point) => (
              <div class={surfaces.stat}>
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="text-sm font-semibold text-white">{point.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-zinc-400">{point.body}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class={`mt-6 grid grid-cols-3 gap-4 border-t ${colors.border} pt-5`}>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Focus</p>
            <p class="mt-1 text-sm font-semibold text-white">Robotics</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Method</p>
            <p class="mt-1 text-sm font-semibold text-white">Build logs</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Scope</p>
            <p class="mt-1 text-sm font-semibold text-white">Hardware</p>
          </div>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <SectionHeader eyebrow="Selected work" title="Project Index" />

      <div class={layout.cardGrid}>
        {projectList.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
