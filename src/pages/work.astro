---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { allProjects, workFocusAreas } from "../data/projects";
---

<BaseLayout title="Work | NearDivine Labs">
  <main class="mx-auto max-w-6xl px-6 pt-32">
    <section class="pb-20">
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.35em] text-zinc-500">
        Work
      </p>

      <h1 class="max-w-4xl text-5xl font-black tracking-tight text-white md:text-7xl">
        Projects, prototypes, build logs, and technical systems.
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        A collection of robotics, drones, embedded hardware, automation systems,
        3D printing work, and software tools.
      </p>

      <div class="mt-10 flex max-w-3xl flex-wrap gap-3">
        {workFocusAreas.map((area) => (
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm font-semibold text-zinc-300">
            {area}
          </span>
        ))}
      </div>
    </section>

    <section class="pb-24">
      <SectionHeader eyebrow="Selected work" title="Project Index" />

      <div class="grid items-start gap-6 md:grid-cols-2 lg:grid-cols-3">
        {allProjects.map((project) => <ProjectCard {...project} />)}
      </div>
    </section>
  </main>
</BaseLayout>