---
import { typography } from "../styles/typography";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import * as projectData from "../data/projects";

const projectModule = projectData as unknown as {
  projects?: any[];
  allProjects?: any[];
  projectList?: any[];
  default?: any[];
};

const projectList =
  projectModule.projects ??
  projectModule.allProjects ??
  projectModule.projectList ??
  projectModule.default ??
  [];

const categories = [
  "Robotics",
  "Drones",
  "3D Printing",
  "Smart Home",
  "Embedded Hardware",
  "Software Tools",
];

const documentationPoints = [
  {
    title: "Build context",
    body: "What was built, tested, repaired, or changed.",
  },
  {
    title: "Failure modes",
    body: "Wiring issues, wrong assumptions, broken parts, and fixes.",
  },
  {
    title: "Next revisions",
    body: "Unfinished work and likely next steps.",
  },
];
---
import { typography } from "../styles/typography";

<BaseLayout title="Work | NearDivine Labs">
  <main class="mx-auto max-w-6xl px-6 pb-24 pt-32">
    <section class="grid gap-12 border-b border-white/10 pb-20 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.25em] text-blue-300">
          Work
        </p>

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Projects, prototypes, build logs, and technical systems.
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-400">
          A portfolio of robotics, drones, embedded hardware, automation systems, 3D printing,
          software tools, and repair work documented through real build progress instead of polished
          summaries only.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {categories.map((category) => (
            <span class="rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-zinc-300">
              {category}
            </span>
          ))}
        </div>
      </div>

      <aside class="overflow-hidden rounded-[2rem] border border-white/10 bg-[#0b0f17]/80 p-6 shadow-2xl shadow-black/30">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-blue-300">
              Portfolio structure
            </p>

            <h2 class={`mt-3 ${typography.cardTitle}`}>
              Project records, not just finished demos.
            </h2>
          </div>

          <span class="shrink-0 rounded-full border border-white/10 px-3 py-1 text-xs font-semibold text-zinc-300">
            Active
          </span>
        </div>

        <div class="mt-6 border-t border-white/10 pt-6">
          <div class="grid gap-3">
            {documentationPoints.map((point) => (
              <div class="rounded-xl border border-white/10 bg-black/30 p-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="text-sm font-semibold text-white">{point.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-zinc-400">{point.body}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-4 border-t border-white/10 pt-5">
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Focus</p>
            <p class="mt-1 text-sm font-semibold text-white">Robotics</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Method</p>
            <p class="mt-1 text-sm font-semibold text-white">Build logs</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">Scope</p>
            <p class="mt-1 text-sm font-semibold text-white">Hardware</p>
          </div>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <SectionHeader eyebrow="Selected work" title="Project Index" />

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projectList.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
