---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { colors, layout, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { allProjects } from "../data/projects";

const categories = [
  "Autonomy Validation",
  "Systems Integration",
  "Embedded Hardware",
  "Robotics",
  "Hardware Test",
  "Networking",
];

const documentationPoints = [
  {
    title: "Role and ownership",
    body: "What I personally assembled, diagnosed, tested, repaired, or documented.",
  },
  {
    title: "System problems",
    body: "Failure modes across power, networking, sensors, compute, actuators, and physical hardware.",
  },
  {
    title: "Evidence and outcomes",
    body: "What became operational, repeatable, better understood, or ready for another revision.",
  },
];

const professionalSlugs = [
  "autonomous-vehicle-sensor-validation",
];

const featuredSlugs = [
  "slimevr-trackers",
  "remote-safe",
  "robotic-spider-platform",
];

const professionalProjects = allProjects.filter((project) =>
  professionalSlugs.includes(project.slug)
);

const featuredProjects = featuredSlugs
  .map((slug) => allProjects.find((project) => project.slug === slug))
  .filter((project) => project !== undefined);

const prioritizedSlugs = new Set([
  ...professionalSlugs,
  ...featuredSlugs,
]);

const additionalProjects = allProjects.filter(
  (project) => !prioritizedSlugs.has(project.slug)
);
---

<BaseLayout title="Work | NearDivine Labs">
  <main class={`${layout.pageShell} pb-24`}>
    <section class={layout.homeHeroGrid}>
      <div>
        <PageEyebrow label="Work" />

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Systems integration, autonomy validation, and embedded hardware.
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-400">
          Professional and independent work showing how I diagnose power,
          networking, sensors, compute, actuators, and physical test
          infrastructure across field and lab environments.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {categories.map((category) => (
            <span class={`${surfaces.pill} px-4 py-2 font-semibold text-zinc-300`}>
              {category}
            </span>
          ))}
        </div>
      </div>

      <aside class={`overflow-hidden ${surfaces.panelStrong}`}>
        <div class="flex items-start justify-between gap-4">
          <div>
            <PageEyebrow label="Engineering evidence" />

            <h2 class={`mt-3 ${typography.cardTitle}`}>
              System problems, personal contribution, and results.
            </h2>
          </div>

          <span class={`${surfaces.pill} shrink-0 text-xs font-semibold text-zinc-300`}>
            Evidence-led
          </span>
        </div>

        <div class={`mt-6 border-t ${colors.border} pt-6`}>
          <div class="grid gap-3">
            {documentationPoints.map((point) => (
              <div class={surfaces.stat}>
                <h3 class="text-sm font-semibold text-white">
                  {point.title}
                </h3>

                <p class="mt-2 text-sm leading-6 text-zinc-400">
                  {point.body}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div class={`mt-6 grid grid-cols-3 gap-4 border-t ${colors.border} pt-5`}>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">
              Focus
            </p>

            <p class="mt-1 text-sm font-semibold text-white">
              Integration
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">
              Method
            </p>

            <p class="mt-1 text-sm font-semibold text-white">
              Diagnose + validate
            </p>
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500">
              Scope
            </p>

            <p class="mt-1 text-sm font-semibold text-white">
              Field + lab
            </p>
          </div>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <SectionHeader
        eyebrow="Autonomy validation"
        title="Professional Case Study"
      />

      <div class={layout.cardGrid}>
        {professionalProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>

    <section class={layout.section}>
      <SectionHeader
        eyebrow="Embedded + robotics"
        title="Featured Systems Work"
      />

      <div class={layout.cardGrid}>
        {featuredProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>

    <section class={layout.section}>
      <SectionHeader
        eyebrow="Project archive"
        title="Additional Builds"
      />

      <div class={layout.cardGrid}>
        {additionalProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>