---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | NearDivine Labs">
  <main class="mx-auto max-w-6xl px-6 pt-32">
    <section class="pb-20">
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.35em] text-zinc-500">
        Contact
      </p>

      <h1 class="max-w-4xl text-5xl font-black tracking-tight text-white md:text-7xl">
        Links, resume, and contact.
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        This page will hold my GitHub, LinkedIn, resume, and direct contact information.
      </p>
    </section>

    <section class="grid gap-6 pb-24 md:grid-cols-3">
      <a href="#" class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition hover:border-blue-400/40 hover:bg-white/[0.06]">
        <h2 class="text-xl font-black text-white">GitHub</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">Project code and repositories.</p>
      </a>

      <a href="#" class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition hover:border-blue-400/40 hover:bg-white/[0.06]">
        <h2 class="text-xl font-black text-white">LinkedIn</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">Professional background and career history.</p>
      </a>

      <a href="#" class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition hover:border-blue-400/40 hover:bg-white/[0.06]">
        <h2 class="text-xl font-black text-white">Resume</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">Resume link will go here once finalized.</p>
      </a>
    </section>
  </main>
</BaseLayout>