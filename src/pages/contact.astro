---
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  {
    title: "GitHub",
    description: "Project repositories, site code, and technical experiments.",
    href: "https://github.com/NearDivine",
    label: "View GitHub",
  },
  {
    title: "LinkedIn",
    description: "Professional background, work history, and career updates.",
    href: "https://www.linkedin.com/in/tyler-funk-17aa123ba/",
    label: "View LinkedIn",
  },
  {
    title: "Resume",
    description: "Resume link will be added after the current version is finalized.",
    href: "",
    label: "Pending",
  },
];
---
import { typography } from "../styles/typography";
import { colors, layout, media, surfaces } from "../styles/siteStyles";

<BaseLayout title="Contact | NearDivine Labs">
  <main class="mx-auto max-w-6xl px-6 pb-24 pt-32">
    <section class={layout.contactHeroGrid}>
      <div>
        <p class={typography.eyebrowMuted}>
          Contact
        </p>

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Links, resume, and professional contact.
        </h1>
      </div>

      <p class="max-w-2xl text-base leading-8 text-zinc-400">
        This page collects the main places to review my work, background, and project history.
        The site itself is the primary portfolio; GitHub and LinkedIn provide supporting context.
      </p>
    </section>

    <section class="pt-16">
      <div class="grid gap-6 md:grid-cols-3">
        {links.map((link) => (
          <article class={`flex min-h-[220px] flex-col ${surfaces.card} p-6`}>
            <div>
              <h2 class="text-xl font-semibold text-white">{link.title}</h2>
              <p class="mt-4 text-sm leading-7 text-zinc-400">
                {link.description}
              </p>
            </div>

            {link.href ? (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class={`mt-auto ${surfaces.buttonSmallSecondary}`}
              >
                {link.label}
              </a>
            ) : (
              <span class={`mt-auto ${surfaces.buttonSmallSecondary} text-zinc-500`}>
                {link.label}
              </span>
            )}
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
