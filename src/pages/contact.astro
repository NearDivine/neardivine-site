---
import PageEyebrow from "../components/PageEyebrow.astro";
import { typography } from "../styles/typography";
import { layout, surfaces } from "../styles/siteStyles";
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  {
    title: "Email",
    description: "thetylerfunk@gmail.com - direct contact for roles and professional conversations.",
    href: "mailto:thetylerfunk@gmail.com",
    label: "Send Email",
  },
  {
    title: "GitHub",
    description: "Project repositories, site code, and technical experiments.",
    href: "https://github.com/NearDivine",
    label: "View GitHub",
  },
  {
    title: "LinkedIn",
    description: "Professional background, work history, and career updates.",
    href: "https://www.linkedin.com/in/tyler-funk-17aa123ba/",
    label: "View LinkedIn",
  },
  {
    title: "Resume",
    description: "One-page resume focused on robotics systems integration, embedded hardware, and autonomy validation.",
    href: "/resume/Tyler_Funk_Resume.pdf",
    label: "Download Resume",
  },
];
---

<BaseLayout
  title="Contact | NearDivine Labs"
  description="Contact Tyler Funk about robotics systems integration, hardware testing, embedded systems, and autonomy validation."
>
  <main class={`${layout.pageShell} pb-24`}>
    <section class={layout.homeHeroGrid}>
      <div>
        <PageEyebrow label="Contact" />

        <h1 class={`mt-4 ${typography.pageTitle}`}>
          Connect about robotics systems, hardware integration, or autonomy validation.
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-400">
          The portfolio documents my technical work in detail. GitHub,
          LinkedIn, and the resume provide supporting project and professional
          context.
        </p>
      </div>

      <aside class={surfaces.panelStrong}>
        <PageEyebrow label="Professional focus" />

        <h2 class={`mt-3 ${typography.cardTitle}`}>
          Roles involving integrated physical systems.
        </h2>

        <div class="mt-6 grid gap-3">
          <div class={surfaces.stat}>
            Robotics systems integration
          </div>

          <div class={surfaces.stat}>
            Hardware integration and test
          </div>

          <div class={surfaces.stat}>
            Autonomy and vehicle validation
          </div>

          <div class={surfaces.stat}>
            Embedded and electromechanical systems
          </div>
        </div>
      </aside>
    </section>

    <section class="pt-16">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {links.map((link) => (
          <article class={`flex min-h-[220px] flex-col ${surfaces.card} p-6`}>
            <div>
              <h2 class="text-xl font-semibold text-white">
                {link.title}
              </h2>

              <p class="mt-4 text-sm leading-7 text-zinc-400">
                {link.description}
              </p>
            </div>

            <a
              href={link.href}
              target={link.title === "Email" || link.title === "Resume" ? undefined : "_blank"}
              rel={link.title === "Email" || link.title === "Resume" ? undefined : "noreferrer"}
              download={link.title === "Resume" ? "Tyler_Funk_Resume.pdf" : undefined}
              class={`mt-auto ${surfaces.buttonSmallSecondary}`}
            >
              {link.label}
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>