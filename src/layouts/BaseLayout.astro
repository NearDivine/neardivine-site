---
import { colors, surfaces } from "../styles/siteStyles";
import Nav from "../components/Nav.astro";
import "../styles/global.css";

const {
  title = "NearDivine Labs",
  description = "Robotics, embedded systems, automation, and technical experiments.",
} = Astro.props;
---
import { colors, surfaces } from "../styles/siteStyles";

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body class={`min-h-screen ${colors.pageBackground} text-white antialiased`}>
    <Nav />
    <slot />
    <div
    id="site-image-lightbox"
    class={surfaces.overlayBackdrop}
    aria-hidden="true"
  >
    <button
      id="site-image-lightbox-close"
      type="button"
      class={surfaces.overlayCloseButton}
      aria-label="Close image preview"
    >
      Close
    </button>

    <div class="flex max-h-[92vh] w-full max-w-7xl flex-col items-center gap-4">
      <img
        id="site-image-lightbox-img"
        src=""
        alt=""
        class="max-h-[84vh] max-w-full rounded-xl object-contain shadow-2xl shadow-black/50"
      />

      <p
        id="site-image-lightbox-caption"
        class="max-w-3xl text-center text-sm leading-6 text-zinc-300"
      ></p>
    </div>
  </div>

  <script is:inline>
    (() => {
      const lightbox = document.getElementById("site-image-lightbox");
      const lightboxImg = document.getElementById("site-image-lightbox-img");
      const caption = document.getElementById("site-image-lightbox-caption");
      const closeButton = document.getElementById("site-image-lightbox-close");

      if (!lightbox || !lightboxImg || !caption || !closeButton) return;

      const openLightbox = (img) => {
        const src = img.currentSrc || img.src;
        const alt = img.alt || "";

        if (!src) return;

        lightboxImg.src = src;
        lightboxImg.alt = alt;
        caption.textContent = alt;
        caption.style.display = alt ? "block" : "none";

        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        lightbox.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      };

      const closeLightbox = () => {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImg.src = "";
        document.body.style.overflow = "";
      };

      document.addEventListener("click", (event) => {
        const target = event.target;

        if (!(target instanceof HTMLImageElement)) return;
        if (!target.closest("main")) return;
        if (target.dataset.noLightbox === "true") return;

        event.preventDefault();
        event.stopPropagation();
        openLightbox(target);
      });

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) closeLightbox();
      });

      closeButton.addEventListener("click", closeLightbox);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeLightbox();
      });

      document.querySelectorAll("main img").forEach((img) => {
        if (img.dataset.noLightbox === "true") return;
        img.classList.add("cursor-zoom-in");
      });
    })();
  </script>
</body>
</html>
