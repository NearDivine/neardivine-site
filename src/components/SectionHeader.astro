---
import { typography } from "../styles/typography";
import { colors } from "../styles/siteStyles";

const { eyebrow, title } = Astro.props;
---

<div class="mb-8">
  {eyebrow && (
    <p class={`mb-2 ${typography.eyebrow}`}>
      {eyebrow}
    </p>
  )}

  <h2 class={typography.sectionTitle}>
    {title}
  </h2>

  <div class={`mt-3 h-1 w-40 rounded-full ${colors.accentBackground}`}></div>
</div>