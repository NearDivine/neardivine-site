---
const { eyebrow, title } = Astro.props;
---

<div class="mb-8">
  {eyebrow && (
    <p class="mb-2 text-xs font-semibold uppercase tracking-[0.25em] text-blue-400">
      {eyebrow}
    </p>
  )}

  <h2 class="text-3xl font-bold tracking-tight text-white">
    {title}
  </h2>

  <div class="mt-3 h-1 w-40 rounded-full bg-blue-500"></div>
</div>
