---
import type { Project } from "../data/projectTypes";

const {
  title,
  category,
  status,
  href,
  image,
  tags = [],
  summary,
}: Project = Astro.props;

const visibleTags = tags.slice(0, 4);
const hiddenTagCount = tags.length - visibleTags.length;
---

<a
  href={href}
  class="group flex h-[430px] max-w-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] transition duration-300 hover:-translate-y-1 hover:border-blue-400/40 hover:bg-white/[0.05]"
>
  <div class="h-40 shrink-0 overflow-hidden border-b border-white/10 bg-gradient-to-br from-blue-500/20 via-zinc-900 to-black">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center px-6 text-center">
        <span class="text-[0.6rem] font-bold uppercase tracking-[0.35em] text-blue-300">
          NearDivine Labs
        </span>
      </div>
    )}
  </div>

  <div class="flex min-h-0 flex-1 flex-col p-5">
    <div class="mb-3 flex items-start justify-between gap-3">
      <p class="project-card-category max-w-[68%] text-[0.62rem] font-black uppercase tracking-[0.22em] text-blue-400">
        {category}
      </p>

      <span class="shrink-0 rounded-full border border-white/10 px-2.5 py-1 text-[0.62rem] font-semibold text-zinc-400">
        {status}
      </span>
    </div>

    <h3 class="project-card-title text-lg font-black leading-tight text-white">
      {title}
    </h3>

    <p class="project-card-summary mt-3 text-sm leading-6 text-zinc-400">
      {summary}
    </p>

    <div class="mt-auto flex flex-wrap gap-2 pt-5">
      {visibleTags.map((tag) => (
        <span class="rounded-full border border-white/10 px-2.5 py-1 text-[0.68rem] text-zinc-500">
          {tag}
        </span>
      ))}

      {hiddenTagCount > 0 && (
        <span class="rounded-full border border-white/10 px-2.5 py-1 text-[0.68rem] text-zinc-500">
          +{hiddenTagCount}
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .project-card-category,
  .project-card-title,
  .project-card-summary {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card-category {
    -webkit-line-clamp: 2;
  }

  .project-card-title {
    -webkit-line-clamp: 2;
  }

  .project-card-summary {
    -webkit-line-clamp: 4;
  }
</style>