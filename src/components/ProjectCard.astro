---
import type { Project } from "../data/projectTypes";

const {
  title,
  category,
  status,
  href,
  image,
  tags = [],
  summary,
}: Project = Astro.props;

const visibleTags = tags.slice(0, 2);
const hiddenTagCount = Math.max(tags.length - visibleTags.length, 0);
---

<a
  href={href}
  class="group flex h-full min-h-[500px] flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] transition duration-300 hover:-translate-y-1 hover:border-blue-400/40 hover:bg-white/[0.05]"
>
  <div class="aspect-[4/3] w-full shrink-0 overflow-hidden border-b border-white/10 bg-gradient-to-br from-blue-500/20 via-zinc-900 to-black">
    {image ? (
      <img
        src={image}
        alt={`${title} project thumbnail`}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center px-6 text-center">
        <span class="text-[0.6rem] font-semibold uppercase tracking-[0.35em] text-blue-300">
          NearDivine Labs
        </span>
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4 flex min-h-[28px] items-start justify-between gap-3">
      <p class="max-w-[65%] truncate text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-blue-400">
        {category}
      </p>

      <span class="max-w-[45%] shrink-0 truncate rounded-full border border-white/10 px-2.5 py-1 text-[0.62rem] font-medium text-zinc-400">
        {status}
      </span>
    </div>

    <h3 class="min-h-[44px] text-base font-semibold leading-snug tracking-[-0.01em] text-white">
      {title}
    </h3>

    <p class="mt-3 text-sm leading-6 text-zinc-400">
      {summary}
    </p>

    <div class="mt-auto grid min-h-[32px] grid-cols-3 gap-2 pt-6">
      {visibleTags.map((tag) => (
        <span class="truncate rounded-full border border-white/10 px-2.5 py-1 text-center text-[0.68rem] text-zinc-500">
          {tag}
        </span>
      ))}

      {hiddenTagCount > 0 && (
        <span class="truncate rounded-full border border-white/10 px-2.5 py-1 text-center text-[0.68rem] text-zinc-500">
          +{hiddenTagCount}
        </span>
      )}
    </div>
  </div>
</a>