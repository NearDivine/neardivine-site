---
const { title, category, status, description, image, href = "/work" } = Astro.props;
---

<a
  href={href}
  class="group block overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] transition hover:-translate-y-1 hover:border-blue-400/40 hover:bg-white/[0.06]"
>
  <div class="aspect-video overflow-hidden bg-zinc-900">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover opacity-80 transition duration-300 group-hover:scale-105 group-hover:opacity-100"
      />
    ) : (
      <div class="flex h-full items-center justify-center bg-gradient-to-br from-blue-500/20 to-zinc-950">
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-blue-300">
          NearDivine Labs
        </span>
      </div>
    )}
  </div>

  <div class="p-5">
    <div class="mb-3 flex items-center justify-between gap-3">
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-300">
        {category}
      </span>

      <span class="rounded-full border border-white/10 px-2 py-1 text-xs text-zinc-400">
        {status}
      </span>
    </div>

    <h3 class="text-lg font-bold text-white group-hover:text-blue-100">
      {title}
    </h3>

    <p class="mt-2 text-sm leading-6 text-zinc-400">
      {description}
    </p>
  </div>
</a>
