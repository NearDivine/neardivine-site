---
import type { Project } from "../data/projectTypes";
import { colors, media, surfaces } from "../styles/siteStyles";
import { typography } from "../styles/typography";

const {
  title,
  category,
  status,
  href,
  image,
  tags = [],
  summary,
}: Project = Astro.props;

const visibleTags = tags.slice(0, 2);
const hiddenTagCount = Math.max(tags.length - visibleTags.length, 0);
---

<a
  href={href}
  class={`group flex h-full min-h-[500px] flex-col overflow-hidden ${surfaces.cardInteractive}`}
>
  <div class={media.cardFrame}>
    {image ? (
      <img
        src={image}
        alt={`${title} project thumbnail`}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class={`flex h-full w-full items-center justify-center px-8 text-center ${colors.surfaceStrong}`}>
        <div>
          <p class={`${typography.tinyLabel} ${colors.accent}`}>
            {category}
          </p>

          <p class="mt-4 text-base font-semibold text-white">
            Project documentation
          </p>

          <p class="mt-2 text-sm leading-6 text-zinc-500">
            Photos will be added soon.
          </p>
        </div>
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4 flex min-h-[28px] items-start justify-between gap-3">
      <p class={`max-w-[65%] truncate ${colors.accent} ${typography.tinyLabel}`}>
        {category}
      </p>

      <span class={`max-w-[45%] shrink-0 truncate font-medium ${surfaces.smallPill}`}>
        {status}
      </span>
    </div>

    <h3 class={`min-h-[44px] ${typography.cardTitle}`}>
      {title}
    </h3>

    <p class="mt-3 text-sm leading-6 text-zinc-400">
      {summary}
    </p>

    <div class="mt-auto grid min-h-[32px] grid-cols-3 gap-2 pt-6">
      {visibleTags.map((tag) => (
        <span class={surfaces.tagPill}>
          {tag}
        </span>
      ))}

      {hiddenTagCount > 0 && (
        <span class={surfaces.tagPill}>
          +{hiddenTagCount}
        </span>
      )}
    </div>
  </div>
</a>