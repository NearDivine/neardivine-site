---
import { layout, surfaces } from "../styles/siteStyles";

const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Work" },
  {
    href: "/resume/Tyler_Funk_Resume.pdf",
    label: "Resume",
  },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const isResumeLink = (href: string) => href.endsWith(".pdf");
---

<nav class={surfaces.navBar}>
  <div class={layout.navShell}>
    <a href="/" class="text-sm font-semibold tracking-[0.28em] text-white">
      NEARDIVINE LABS
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          target={isResumeLink(link.href) ? "_blank" : undefined}
          rel={isResumeLink(link.href) ? "noreferrer" : undefined}
          class:list={[
            "rounded-full px-4 py-2 text-sm font-medium transition",
            isActive(link.href)
              ? surfaces.navActive
              : "text-zinc-400 hover:bg-white/5 hover:text-white",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block">
      <a href="/contact" class={surfaces.navButton}>
        Contact
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class={`list-none ${surfaces.navButton}`}>
        Menu
      </summary>

      <div class={surfaces.navMenu}>
        {links.map((link) => (
          <a
            href={link.href}
            target={isResumeLink(link.href) ? "_blank" : undefined}
            rel={isResumeLink(link.href) ? "noreferrer" : undefined}
            class:list={[
              "block rounded-xl px-4 py-3 text-sm font-semibold transition",
              isActive(link.href)
                ? surfaces.navActive
                : "text-zinc-300 hover:bg-white/5 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </details>
  </div>
</nav>