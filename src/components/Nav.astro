---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Work" },
  { href: "/capsule", label: "Capsule" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav class="fixed left-0 top-0 z-50 w-full border-b border-white/5 bg-[#08090d]/90 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="text-sm font-semibold tracking-[0.28em] text-white">
      NEARDIVINE LABS
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-full px-4 py-2 text-sm font-medium transition",
            isActive(link.href)
              ? "bg-blue-500/15 text-blue-300"
              : "text-zinc-400 hover:bg-white/5 hover:text-white",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block">
      <a
        href="/contact"
        class="rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-white hover:bg-white/5"
      >
        Contact
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class="list-none rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-white hover:bg-white/5">
        Menu
      </summary>

      <div class="absolute right-0 mt-3 w-52 rounded-2xl border border-white/10 bg-[#08090d] p-2 shadow-2xl shadow-black/50">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "block rounded-xl px-4 py-3 text-sm font-semibold transition",
              isActive(link.href)
                ? "bg-blue-500/15 text-blue-300"
                : "text-zinc-300 hover:bg-white/5 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </details>
  </div>
</nav>
