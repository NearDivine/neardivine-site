---
import type { ProjectGalleryImage } from "../data/projectTypes";
import type {
  ProjectImageEvidenceType,
  ProjectImagePhase,
} from "../data/imageStandards";
import { imageEvidenceTypeStandards } from "../data/imageStandards";
import { layout, media, surfaces } from "../styles/siteStyles";
import { typography } from "../styles/typography";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  images?: ProjectGalleryImage[];
  eyebrow?: string;
  title?: string;
  description?: string;
  groupBy?: "phase" | "evidenceType";
  includeTypes?: ProjectImageEvidenceType[];
  includePhases?: ProjectImagePhase[];
  emptyMessage?: string;
}

const {
  images = [],
  eyebrow = "Evidence",
  title = "Project Evidence",
  description,
  groupBy = "phase",
  includeTypes,
  includePhases,
  emptyMessage = "No evidence images added yet.",
} = Astro.props;

const evidenceOrder: ProjectImageEvidenceType[] = [
  "showcase",
  "build",
  "test",
  "configuration",
  "failure",
  "repair",
  "archive",
];

const phaseOrder = [
  "ungrouped",
  "concept",
  "v1",
  "v2",
  "rebuild",
  "current",
] as const;

type GalleryPhaseGroup = (typeof phaseOrder)[number];

const phaseLabels: Record<GalleryPhaseGroup, string> = {
  ungrouped: "Project Evidence",
  concept: "Concept / Early Direction",
  v1: "V1 / Original Build",
  v2: "V2 / Updated Build",
  rebuild: "Rebuild / Current Cleanup",
  current: "Current State",
};

const phaseDescriptions: Record<GalleryPhaseGroup, string> = {
  ungrouped:
    "Project photos showing build process, testing, troubleshooting, and historical context.",
  concept:
    "Early reference material kept to show where the project started.",
  v1:
    "Earlier project photos showing original build context, rough process documentation, troubleshooting, and lessons learned.",
  v2:
    "Updated project photos showing a later version, cleanup pass, rebuild, or improved documentation.",
  rebuild:
    "Rebuild photos showing cleaned-up implementation, improved presentation, and updated documentation standards.",
  current:
    "Current-state photos intended to represent the project as it should appear now.",
};

const includedTypes = includeTypes ? new Set(includeTypes) : null;
const includedPhases = includePhases ? new Set<GalleryPhaseGroup>(includePhases) : null;

const getEvidenceType = (image: ProjectGalleryImage): ProjectImageEvidenceType =>
  image.evidenceType ?? "build";

const getPhase = (image: ProjectGalleryImage): GalleryPhaseGroup =>
  image.phase ?? "ungrouped";

const getFrameClass = (image: ProjectGalleryImage) => {
  if (image.variant === "portrait") return media.portraitFrame;
  if (image.variant === "archive" || image.quality === "archive") return media.archiveFrame;
  return media.galleryFrame;
};

const getImageFitClass = (_image: ProjectGalleryImage) => {
  return "object-cover";
};

const getEvidenceLabel = (image: ProjectGalleryImage) => {
  const type = getEvidenceType(image);

  return imageEvidenceTypeStandards[type]?.label ?? type;
};

const visibleImages = images.filter((image) => {
  const type = getEvidenceType(image);
  const phase = getPhase(image);

  if (includedTypes && !includedTypes.has(type)) return false;
  if (includedPhases && !includedPhases.has(phase)) return false;

  return true;
});

const groupedImages =
  groupBy === "phase"
    ? phaseOrder
        .map((phase) => ({
          key: phase,
          label: phaseLabels[phase],
          useCase: phaseDescriptions[phase],
          images: visibleImages.filter((image) => getPhase(image) === phase),
        }))
        .filter((group) => group.images.length > 0)
    : evidenceOrder
        .map((type) => ({
          key: type,
          label: imageEvidenceTypeStandards[type].label,
          useCase: imageEvidenceTypeStandards[type].useCase,
          images: visibleImages.filter((image) => getEvidenceType(image) === type),
        }))
        .filter((group) => group.images.length > 0);
---

<section class={layout.sectionBottom}>
  <SectionHeader eyebrow={eyebrow} title={title} />

  {description && (
    <p class={`${layout.contentMeasure} ${typography.body}`}>
      {description}
    </p>
  )}

  {groupedImages.length > 0 ? (
    <div class="mt-10 space-y-14">
      {groupedImages.map((group) => (
        <section>
          <div class="mb-5">
            <p class={typography.eyebrowMuted}>
              {group.label}
            </p>

            <p class={`mt-2 ${typography.meta}`}>
              {group.useCase}
            </p>
          </div>

          <div class={layout.cardGrid}>
            {group.images.map((image) => (
              <figure class={`flex h-full flex-col overflow-hidden ${surfaces.card}`}>
                <div class={`${getFrameClass(image)} shrink-0`}>
                  <img
                    src={image.src}
                    alt={image.alt ?? image.title}
                    class={`h-full w-full ${getImageFitClass(image)}`}
                    loading="lazy"
                    decoding="async"
                  />
                </div>

                <div class="flex flex-1 flex-col p-5">
                  <h3 class={typography.galleryTitle}>
                    {image.title}
                  </h3>

                  <p class={`mt-2 ${typography.caption}`}>
                    {image.caption}
                  </p>

                  <div class="mt-auto pt-5">
                    <p class={typography.tinyLabel}>
                      {getEvidenceLabel(image)}
                    </p>
                  </div>
                </div>
              </figure>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : (
    <p class={`${layout.contentMeasure} ${typography.body}`}>
      {emptyMessage}
    </p>
  )}
</section>